# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  تنظیمات ربات مانیتور گروه تلگرام
#  Telegram Group Monitor Bot Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔑 توکن ربات تلگرام (از @BotFather دریافت کنید)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 👤 آیدی عددی ادمین‌های کل ربات (با کاما جدا کنید)
# مثال: 123456789,987654321
ADMIN_IDS=

# 🗄️ مسیر دیتابیس SQLite
DATABASE_PATH=data/bot.db

# 📝 سطح لاگ (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ⏱️ فاصله بررسی تغییر پروفایل (ثانیه)
PROFILE_CHECK_INTERVAL=3600
